# Medium Publishing
# Get your integration token: https://medium.com/me/settings → Security → Integration tokens
MEDIUM_TOKEN=your_medium_integration_token_here

# Get your author ID by running:
# curl -H "Authorization: Bearer <your_token>" https://api.medium.com/v1/me
MEDIUM_AUTHOR_ID=your_medium_author_id_here

# Tavily Search API — https://tavily.com
TAVILY_API_KEY=tvly-your_tavily_key_here

# Anthropic API (used by CrewAI for the LLM) — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here
